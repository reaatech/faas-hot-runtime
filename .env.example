# MCP Server Configuration
MCP_PORT=8080
MCP_HOST=0.0.0.0
API_KEY=your-api-key-here

# Kubernetes Configuration
KUBECONFIG_PATH=./kubeconfigs/config
K8S_NAMESPACE=faas-hot-runtime
K8S_CLUSTER=eks-cluster

# Cloud Provider Configuration
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
GCP_PROJECT_ID=your-gcp-project
GCP_KEY_FILE=./gcp-key.json

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=faas-hot-runtime
OTEL_RESOURCE_ATTRIBUTES=service.version=0.1.0

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Pool Configuration
DEFAULT_MIN_POOL_SIZE=2
DEFAULT_MAX_POOL_SIZE=10
DEFAULT_TARGET_UTILIZATION=0.7

# Cost Configuration
DAILY_BUDGET_LIMIT=100.00
COST_ALERT_THRESHOLDS=0.5,0.75,0.9

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Timeout Configuration (milliseconds)
DEFAULT_TIMEOUT_MS=30000
HEALTH_CHECK_INTERVAL_MS=5000
